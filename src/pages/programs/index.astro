---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const programs = await getCollection('programs');
// Sort by order field
const sortedPrograms = programs.sort((a, b) => (a.data.order || 99) - (b.data.order || 99));
---

<Layout title="Programs" currentPath="/programs">
  <div class="section-nav">
    <a href="/programs" class="active">Programs Overview</a>
    <a href="/programs/free-first-consultation">Free Consultation</a>
    <a href="/programs/the-splint">Splints I Use</a>
    <a href="/programs/program-option-1">Program Option 1</a>
    <a href="/programs/program-option-2">Program Option 2</a>
    <a href="/programs/coping-without-retraining">Coping Options</a>
  </div>

  <article>
    <h1>Retraining Programs & Support</h1>
    <p>I offer several options to help musicians retrain their motor control, manage symptoms, and design orthotics to bypass focal hand dystonia blocks.</p>
    
    <h2>Options & Resources</h2>
    <div class="card-grid">
      {sortedPrograms.map(program => (
        <a href={`/programs/${program.id}`} class="card">
          <h3>{program.data.title}</h3>
          <p>{program.data.description}</p>
        </a>
      ))}
    </div>
  </article>
</Layout>
