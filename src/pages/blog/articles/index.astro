---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

const articles = await getCollection('blog');

const base = import.meta.env.BASE_URL;
---

<Layout title="Articles" currentPath="/blog/articles">
  <div class="section-nav">
    <a href={`${base}blog`}>Blog Overview</a>
    <a href={`${base}blog/articles`} class="active">Articles List</a>
  </div>

  <article>
    <h1>All Articles</h1>
    <p>Read detailed articles written to help musicians understand the neurology, ergonomics, and daily practice of focal dystonia recovery.</p>
    
    <div style="margin: 2rem 0;">
      {articles.map(article => (
        <article style="margin-bottom: 2rem; border-bottom: 1px solid var(--border); padding-bottom: 1.5rem;">
          <h3><a href={`${base}blog/articles/${article.id}`}>{article.data.title}</a></h3>
          <p style="color: var(--text-muted); font-size: 0.95rem;">{article.data.description}</p>
        </article>
      ))}
    </div>
  </article>
</Layout>
