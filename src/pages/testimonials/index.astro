---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const testimonials = await getCollection('testimonials');
---

<Layout title="Testimonials" currentPath="/testimonials">
  <div class="section-nav">
    <a href="/testimonials" class="active">Testimonials Overview</a>
    <a href="/testimonials/classical-guitarist-index-finger-fd">Right Hand Index Finger</a>
    <a href="/testimonials/guitarist-left-fretting-hand-dystonia">Left Fretting Hand</a>
    <a href="/testimonials/guitarist-fretting-hand-dystonia-recovery">Fretting Hand Recovery</a>
  </div>

  <article>
    <h1>Testimonials & Case Studies</h1>
    <p>Read about the experiences of professional and advanced musicians who have undergone focal hand dystonia retraining under my guidance.</p>
    
    <h2>Individual Stories</h2>
    <div class="card-grid">
      {testimonials.map(testimonial => (
        <a href={`/testimonials/${testimonial.id}`} class="card">
          <h3>{testimonial.data.title}</h3>
          <p>{testimonial.data.description}</p>
        </a>
      ))}
    </div>
  </article>
</Layout>
